# GMGN API
GMGN_API_KEY=your_gmgn_api_key
GMGN_PRIVATE_KEY=your_private_key_for_trade_signing   # Ed25519 atau RSA
GMGN_WALLET_ADDRESS=your_wallet_address
GMGN_CHAIN=sol

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/elephant-alpha            # atau model lain yang cepat & murah

# Trading Config
MAX_OPEN_POSITIONS=5               # Maks posisi terbuka sekaligus
TAKE_PROFIT_PERCENT=50             # Take profit di +50%
STOP_LOSS_PERCENT=30               # Stop loss di -30%
SCAN_INTERVAL_MINUTES=0.5          # Screening: scan trenches setiap 0.5 menit (30 detik)
MANAGE_INTERVAL_MINUTES=0.1667     # Managing: monitor posisi terbuka setiap 0.1667 menit (10 detik)
SLIPPAGE=0.15                      # 15% slippage untuk trenches
AMOUNT_SOL=0.1                     # Jumlah SOL untuk setiap buy order

# GMGN Trenches Parameters
GMGN_SORT_BY=                      # Sort field: smart_degen_count, renowned_count, volume_24h, volume_1h, swaps_24h, swaps_1h, rug_ratio, holder_count, usd_market_cap, created_timestamp
GMGN_LIMIT=                        # Max tokens to return
GMGN_TYPE=completed                # Type field: new_creation, near_completion, completed
GMGN_LAUNCHPAD_PLATFORM=Pump.fun   # Launchpad platform filter, repeatable (default: all platforms for the chain)

# GMGN Trenches Filters (Server-side) - min & max untuk semua filter yang didukung
GMGN_FILTER_PRESET=                       # Filter preset: safe -> max_rug_ratio=0.3 + max_bundler_rate=0.3 + max_insider_ratio=0.3 | smart-money -> min_smart_degen_count=1 | strict -> max_rug_ratio=0.3 + max_bundler_rate=0.3 + max_insider_ratio=0.3 + min_smart_degen_count=1 + min_volume_24h=1000
GMGN_MIN_VOLUME_24H=                      # Minimal 24h volume (USD)
GMGN_MAX_VOLUME_24H=                      # Maximal 24h volume (USD)
GMGN_MIN_NET_BUY_24H=                     # Minimal 24h net buy (USD)
GMGN_MAX_NET_BUY_24H=                     # Maximal 24h net buy (USD)
GMGN_MIN_SWAPS_24H=                       # Minimal 24h swap count
GMGN_MAX_SWAPS_24H=                       # Maximal 24h swap count
GMGN_MIN_BUYS_24H=                        # Minimal 24h buy count
GMGN_MAX_BUYS_24H=                        # Maximal 24h buy count
GMGN_MIN_SELLS_24H=                       # Minimal 24h sell count
GMGN_MAX_SELLS_24H=                       # Maximal 24h sell count
GMGN_MIN_VISITING_COUNT=                  # Minimal visiting count
GMGN_MAX_VISITING_COUNT=                  # Maximal visiting count
GMGN_MIN_PROGRESS=                        # Minimal bonding curve progress (0-1)
GMGN_MAX_PROGRESS=                        # Maximal bonding curve progress (0-1)
GMGN_MIN_MARKETCAP=                       # Minimal market cap (USD)
GMGN_MAX_MARKETCAP=                       # Maximal market cap (USD)
GMGN_MIN_LIQUIDITY=                       # Minimal liquidity (USD)
GMGN_MAX_LIQUIDITY=                       # Maximal liquidity (USD)
GMGN_MIN_CREATED=                         # Minimal token age (e.g. 1m, 5m, 1h, 24h)
GMGN_MAX_CREATED=                         # Maximal token age
GMGN_MIN_HOLDER_COUNT=                    # Minimal holder count
GMGN_MAX_HOLDER_COUNT=                    # Maximal holder count
GMGN_MIN_TOP_HOLDER_RATE=                 # Minimal top-10 holder rate (0-1)
GMGN_MAX_TOP_HOLDER_RATE=                 # Maximal top-10 holder rate (0-1)
GMGN_MIN_RUG_RATIO=                       # Minimal rug ratio (0-1)
GMGN_MAX_RUG_RATIO=                       # Maximal rug ratio (0-1)
GMGN_MIN_BUNDLER_RATE=                    # Minimal bundler rate (0-1)
GMGN_MAX_BUNDLER_RATE=                    # Maximal bundler rate (0-1)
GMGN_MIN_INSIDER_RATIO=                   # Minimal insider ratio (0-1)
GMGN_MAX_INSIDER_RATIO=                   # Maximal insider ratio (0-1)
GMGN_MIN_ENTRAPMENT_RATIO=                # Minimal entrapment ratio (0-1)
GMGN_MAX_ENTRAPMENT_RATIO=                # Maximal entrapment ratio (0-1)
GMGN_MIN_PRIVATE_VAULT_HOLD_RATE=         # Minimal private vault hold rate (0-1)
GMGN_MAX_PRIVATE_VAULT_HOLD_RATE=         # Maximal private vault hold rate (0-1)
GMGN_MIN_TOP70_SNIPER_HOLD_RATE=          # Minimal top-70 sniper hold rate (0-1)
GMGN_MAX_TOP70_SNIPER_HOLD_RATE=          # Maximal top-70 sniper hold rate (0-1)
GMGN_MIN_BOT_COUNT=                       # Minimal bot count
GMGN_MAX_BOT_COUNT=                       # Maximal bot count
GMGN_MIN_BOT_DEGEN_RATE=                  # Minimal bot-degen rate (0-1)
GMGN_MAX_BOT_DEGEN_RATE=                  # Maximal bot-degen rate (0-1)
GMGN_MIN_FRESH_WALLET_RATE=               # Minimal fresh wallet rate (0-1)
GMGN_MAX_FRESH_WALLET_RATE=               # Maximal fresh wallet rate (0-1)
GMGN_MIN_TOTAL_FEE=                       # Minimal total fee
GMGN_MAX_TOTAL_FEE=                       # Maximal total fee
GMGN_MIN_SMART_DEGEN_COUNT=               # Minimal smart degen count
GMGN_MAX_SMART_DEGEN_COUNT=               # Maximal smart degen count
GMGN_MIN_RENOWNED_COUNT=                  # Minimal renowned count
GMGN_MAX_RENOWNED_COUNT=                  # Maximal renowned count
GMGN_MIN_CREATOR_BALANCE_RATE=            # Minimal creator balance rate (0-1)
GMGN_MAX_CREATOR_BALANCE_RATE=            # Maximal creator balance rate (0-1)
GMGN_MIN_CREATOR_CREATED_COUNT=           # Minimal creator created count
GMGN_MAX_CREATOR_CREATED_COUNT=           # Maximal creator created count
GMGN_MIN_CREATOR_CREATED_OPEN_COUNT=      # Minimal creator created open count
GMGN_MAX_CREATOR_CREATED_OPEN_COUNT=      # Maximal creator created open count
GMGN_MIN_CREATOR_CREATED_OPEN_RATIO=      # Minimal creator created open ratio (0-1)
GMGN_MAX_CREATOR_CREATED_OPEN_RATIO=      # Maximal creator created open ratio (0-1)
GMGN_MIN_X_FOLLOWER=                      # Minimal X follower count
GMGN_MAX_X_FOLLOWER=                      # Maximal X follower count
GMGN_MIN_TWITTER_RENAME_COUNT=            # Minimal Twitter rename count
GMGN_MAX_TWITTER_RENAME_COUNT=            # Maximal Twitter rename count
GMGN_MIN_TG_CALL_COUNT=                   # Minimal Telegram call count
GMGN_MAX_TG_CALL_COUNT=                   # Maximal Telegram call count

# Agent
DRY_RUN=true                       # true = simulasi, false = live trading
TEMPERATURE=0.1                    # Kemampuan AI untuk bereksplorasi (0-1)
MAX_TOKENS=3000                    # Maksimal token yang digunakan untuk memberikan keputusan
LOG_LEVEL=info
